# Speedtest Tracker - Track internet speeds over time
# Copy to app.env and customize before starting

# Timezone
TZ=America/New_York

# Hostname / Domain
BASE_HOST_NAME=${HOSTNAME}
BASE_DOMAIN_NAME=example.com

# Service user/group
SERVICE_USER=1000
SERVICE_GROUP=1000

# Application name shown in UI
APP_NAME=Speedtest Results

# Admin account
APP_ADMIN_NAME=administrator
APP_ADMIN_USER=admin@example.com
APP_ADMIN_PASS=changeme_admin_password

# Application key (Laravel key; prefix with "base64:" for base64-encoded key)
APP_SECRET_KEY=changeme_secret_key_min_32_chars

# Cron schedule for running speed tests (default: every 4 hours)
SPEEDTEST_SCHEDULE=0 */4 * * *

# Specific Ookla server IDs to test against (comma-separated, empty = automatic)
SPEEDTEST_SERVERS=

# Prune results older than N days (0 = keep forever)
PRUNE_RESULTS_OLDER_THAN=0
